{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SysmonWidget",
  "version": "2.0.0",
  "identifier": "com.corentingodon.sysmonwidget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SysmonWidget",
        "width": 320,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["hardware/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
